<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <Button
        android:id="@+id/btn_hapus"
        android:layout_width="192dp"
        android:layout_height="47dp"
        android:backgroundTint="@color/Orange"
        android:text="Hapus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_ubah"
        app:layout_constraintTop_toTopOf="@+id/btn_ubah" />

    <Button
        android:id="@+id/btn_ubah"
        android:layout_width="187dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/Green"
        android:text="Ubah"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewProvinsiUser" />

    <TextView
        android:id="@+id/textViewNamaUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="TextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewPhoneUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="TextView"
        app:layout_constraintStart_toStartOf="@+id/textViewNamaUser"
        app:layout_constraintTop_toBottomOf="@+id/textViewNamaUser" />

    <TextView
        android:id="@+id/textViewAlamatUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="TextView"
        app:layout_constraintStart_toStartOf="@+id/textViewPhoneUser"
        app:layout_constraintTop_toBottomOf="@+id/textViewPhoneUser" />

    <TextView
        android:id="@+id/textViewProvinsiUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="TextView"
        app:layout_constraintStart_toStartOf="@+id/textViewAlamatUser"
        app:layout_constraintTop_toBottomOf="@+id/textViewAlamatUser" />

</androidx.constraintlayout.widget.ConstraintLayout>